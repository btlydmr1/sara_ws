<?xml version="1.0"?>
<!--
  SARA roketi - YATAY + MERKEZ referanslı
  Origin (base_link) roketin GEOMETRİK MERKEZİNDE -> roket kendi ortası etrafında döner.
  Z offset 0.4968 m: gövde ve kanatçıklar bu kadar kaydırıldı (mesh'ler değişmedi).
-->
<robot name="sara_rocket">

  <material name="govde_gri">
    <color rgba="0.75 0.75 0.78 1.0"/>
  </material>
  <material name="kanatcik_mavi">
    <color rgba="0.10 0.45 0.85 1.0"/>
  </material>

  <link name="base_link"/>

  <joint name="body_visual_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rocket_body"/>
    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- Gövde: merkeze kaydırıldı (Z -0.4968) -->
  <link name="rocket_body">
    <visual>
      <origin xyz="0 0 -0.4968" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://sara_description/meshes/body.stl"/>
      </geometry>
      <material name="govde_gri"/>
    </visual>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <!-- Kanatçıklar: Z 0.178 -> -0.3188 (aynı 0.4968 kayma) -->
  <link name="fin_px">
    <visual>
      <origin xyz="0 0 -0.4968" rpy="0 0 0"/>
      <geometry><mesh filename="package://sara_description/meshes/fin_px.stl"/></geometry>
      <material name="kanatcik_mavi"/>
    </visual>
    <inertial><mass value="0.05"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
  </link>
  <joint name="fin_px_joint" type="revolute">
    <parent link="rocket_body"/>
    <child link="fin_px"/>
    <origin xyz="0.075 0 -0.3188" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.6" upper="0.6" effort="10" velocity="10"/>
  </joint>

  <link name="fin_nx">
    <visual>
      <origin xyz="0 0 -0.4968" rpy="0 0 0"/>
      <geometry><mesh filename="package://sara_description/meshes/fin_nx.stl"/></geometry>
      <material name="kanatcik_mavi"/>
    </visual>
    <inertial><mass value="0.05"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
  </link>
  <joint name="fin_nx_joint" type="revolute">
    <parent link="rocket_body"/>
    <child link="fin_nx"/>
    <origin xyz="-0.075 0 -0.3188" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.6" upper="0.6" effort="10" velocity="10"/>
  </joint>

  <link name="fin_py">
    <visual>
      <origin xyz="0 0 -0.4968" rpy="0 0 0"/>
      <geometry><mesh filename="package://sara_description/meshes/fin_py.stl"/></geometry>
      <material name="kanatcik_mavi"/>
    </visual>
    <inertial><mass value="0.05"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
  </link>
  <joint name="fin_py_joint" type="revolute">
    <parent link="rocket_body"/>
    <child link="fin_py"/>
    <origin xyz="0 0.075 -0.3188" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.6" upper="0.6" effort="10" velocity="10"/>
  </joint>

  <link name="fin_ny">
    <visual>
      <origin xyz="0 0 -0.4968" rpy="0 0 0"/>
      <geometry><mesh filename="package://sara_description/meshes/fin_ny.stl"/></geometry>
      <material name="kanatcik_mavi"/>
    </visual>
    <inertial><mass value="0.05"/><inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/></inertial>
  </link>
  <joint name="fin_ny_joint" type="revolute">
    <parent link="rocket_body"/>
    <child link="fin_ny"/>
    <origin xyz="0 -0.075 -0.3188" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.6" upper="0.6" effort="10" velocity="10"/>
  </joint>

</robot>
